generator client {
  provider      = "prisma-client-js"
  output        = "../node_modules/.prisma/recon-client"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model BankRecon {
  id          String    @id @default(uuid())
  tenantId    String    @map("tenant_id")
  accountName String    @map("account_name")
  reconDate   DateTime  @map("recon_date")
  glBalance   Decimal   @map("gl_balance")   @db.Decimal(15, 2)
  bankBalance Decimal   @map("bank_balance") @db.Decimal(15, 2)
  variance    Decimal   @default(0)          @db.Decimal(15, 2)
  status      String    @default("OPEN")
  lockedBy    String?   @map("locked_by")
  lockedAt    DateTime? @map("locked_at")

  transactions BankTransaction[]

  @@map("bank_recons")
  @@index([tenantId])
}

model BankTransaction {
  id                   String  @id @default(uuid())
  bankReconId          String  @map("bank_recon_id")
  transactionDate      DateTime @map("transaction_date")
  description          String
  amount               Decimal  @db.Decimal(15, 2)
  matchedJournalLineId String? @map("matched_journal_line_id")
  status               String  @default("UNMATCHED")

  bankRecon BankRecon @relation(fields: [bankReconId], references: [id])

  @@map("bank_transactions")
  @@index([bankReconId])
  @@index([bankReconId, status])
}
