generator client {
  provider      = "prisma-client-js"
  output        = "../node_modules/.prisma/eom-client"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "darwin-arm64"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model EOMClose {
  id            String    @id @default(uuid())
  tenantId      String    @map("tenant_id")
  periodYear    Int       @map("period_year")
  periodMonth   Int       @map("period_month")
  // MONTHLY | YEAR_END | 13TH_MONTH
  // @trace-cobol purge.cbl (MONTHLY) + yrend.cbl (YEAR_END)
  closeType     String    @default("MONTHLY") @map("close_type")
  status        String    @default("NOT_STARTED")
  currentStep   String?   @map("current_step")
  startedAt     DateTime  @default(now()) @map("started_at")
  completedAt   DateTime? @map("completed_at")
  blockedReason String?   @map("blocked_reason")
  // Audit trail — COBOL had no user attribution
  initiatedBy   String?   @map("initiated_by")

  steps   EOMStep[]
  backups EOmBackup[]

  @@unique([tenantId, periodYear, periodMonth, closeType])
  @@map("eom_closes")
  @@index([tenantId])
}

/// BUILD-012: Pre-purge snapshot for disaster recovery
/// Stores GL account opening balances and period balances before destructive operations
model EOmBackup {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  eomCloseId  String   @map("eom_close_id")
  backupType  String   @map("backup_type")  // GL_ACCOUNTS | PERIOD_BALANCES
  backupData  Json     @map("backup_data")
  createdAt   DateTime @default(now()) @map("created_at")

  eomClose EOMClose @relation(fields: [eomCloseId], references: [id])

  @@map("eom_backups")
  @@index([eomCloseId])
  @@index([tenantId])
}

model EOMStep {
  id           String    @id @default(uuid())
  eomCloseId   String    @map("eom_close_id")
  stepCode     String    @map("step_code")
  stepName     String    @map("step_name")
  status       String    @default("PENDING")
  startedAt    DateTime? @map("started_at")
  completedAt  DateTime? @map("completed_at")
  errorMessage String?   @map("error_message")
  retryCount   Int       @default(0) @map("retry_count")

  eomClose EOMClose @relation(fields: [eomCloseId], references: [id])

  @@map("eom_steps")
  @@index([eomCloseId])
}

// Idempotency token for year-end close.
// Replaces the histtran key lookup in yrend.cbl (YE-INV-02):
//   HISTTRAN key = source + date + "EOY{YEAR}" + DUPEREFNO=0 + LINENO=1
// The DB-level unique constraint enforces the same invariant with simpler code.
// @trace-cobol yrend.cbl YE-INV-02
// @intelligence-additions Dedicated table vs. in-band histtran key check
model YearEndRecord {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  fiscalYear  Int      @map("fiscal_year")
  closedAt    DateTime @default(now()) @map("closed_at")
  initiatedBy String   @map("initiated_by")

  @@unique([tenantId, fiscalYear])
  @@map("year_end_records")
  @@index([tenantId])
}

/// @cobol-origin KOMFCAL — fiscal calendar definition and period status tracking
/// Enables 13th month support and centralized period lifecycle management (FIX-021)
model FiscalPeriod {
  id           String    @id @default(uuid())
  tenantId     String    @map("tenant_id")
  fiscalYear   Int       @map("fiscal_year")
  periodNumber Int       @map("period_number")
  startDate    DateTime  @map("start_date") @db.Date
  endDate      DateTime  @map("end_date") @db.Date
  /// OPEN | CLOSED | ADJUSTMENT | YEAR_END
  status       String    @default("OPEN")
  closedAt     DateTime? @map("closed_at")
  closedBy     String?   @map("closed_by")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@unique([tenantId, fiscalYear, periodNumber])
  @@map("fiscal_periods")
  @@index([tenantId, fiscalYear])
  @@index([tenantId, status])
}

/// Outbox pattern for reliable event publishing from eom-service.
/// Written inside $transaction alongside state changes — never via direct publish.
model OutboxEvent {
  id            String    @id @default(uuid())
  eventType     String    @map("event_type")
  tenantId      String    @map("tenant_id")
  payload       Json
  correlationId String?   @map("correlation_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  publishedAt   DateTime? @map("published_at")
  retryCount    Int       @default(0) @map("retry_count")
  lastError     String?   @map("last_error")

  @@map("outbox_events")
  @@index([publishedAt, retryCount])
  @@index([createdAt])
  @@index([tenantId])
}
